# 复制本文件为 .env 后填写，切勿将 .env 提交到 Git
DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-this-to-a-random-32-char-string"
ENCRYPTION_KEY="change-this-to-another-random-32-char-string"
STARTGG_API_TOKEN=""
NODE_ENV="development"
# 生产环境必填：浏览器地址栏中的主机名（IP 或域名），多个用英文逗号分隔，不要写 http://
# 例：123.45.67.89  或  ebifightclub.cn,www.ebifightclub.cn
SERVER_ACTION_ALLOWED_ORIGINS=""
